{
  "name": "revika-djaya-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "seed:units": "bun run src/lib/db/seeds/seed-default-units.ts",
    "seed:cost-items": "bun run src/lib/db/seeds/seed-default-cost-items.ts",
    "seed:products": "bun run src/lib/db/seeds/seed-default-products.ts",
    "seed:recipes": "bun run src/lib/db/seeds/seed-default-recipes.ts",
    "seed:inventory": "bun run src/lib/db/seeds/seed-opening-inventory.ts",
    "seed:reset": "bun run src/lib/db/seeds/reset-demo-seed.ts",
    "seed:refresh": "bun run seed:reset && bun run seed:all",
    "seed:all": "bun run seed:units && bun run seed:cost-items && bun run seed:products && bun run seed:recipes && bun run seed:inventory",
    "commit": "git add -A && git commit"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.574.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
